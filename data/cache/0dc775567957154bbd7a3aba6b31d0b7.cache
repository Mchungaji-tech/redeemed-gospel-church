a:2:{s:7:"expires";i:1784224010;s:7:"content";a:6:{i:0;a:4:{s:2:"id";i:1;s:4:"name";s:16:"Worship Ministry";s:11:"description";s:114:"Leading the church in praise and worship. We exist to create an atmosphere for people to encounter God's presence.";s:10:"created_at";s:19:"2026-07-16 02:11:29";}i:1;a:4:{s:2:"id";i:2;s:4:"name";s:14:"Youth Ministry";s:11:"description";s:111:"Equipping young people with truth and purpose. We disciple the next generation to become leaders in the church.";s:10:"created_at";s:19:"2026-07-16 02:11:29";}i:2;a:4:{s:2:"id";i:3;s:4:"name";s:19:"Evangelism Ministry";s:11:"description";s:113:"Taking the Gospel to communities and nations. We organize crusades and outreach programs to win souls for Christ.";s:10:"created_at";s:19:"2026-07-16 02:11:29";}i:3;a:4:{s:2:"id";i:4;s:4:"name";s:14:"Men's Ministry";s:11:"description";s:101:"Equipping men for leadership in the home, church, and community. Building strong fathers and leaders.";s:10:"created_at";s:19:"2026-07-16 02:11:29";}i:4;a:4:{s:2:"id";i:5;s:4:"name";s:16:"Women's Ministry";s:11:"description";s:98:"Empowering women to fulfill their God-given potential. Building a sisterhood of faith and service.";s:10:"created_at";s:19:"2026-07-16 02:11:29";}i:5;a:4:{s:2:"id";i:6;s:4:"name";s:19:"Children's Ministry";s:11:"description";s:100:"Nurturing children in the ways of the Lord. We teach them to love God and His Word from a young age.";s:10:"created_at";s:19:"2026-07-16 02:11:29";}}}