a:2:{s:7:"expires";i:1784224010;s:7:"content";a:4:{i:0;a:4:{s:2:"id";i:1;s:5:"title";s:22:"Community Food Support";s:11:"description";s:115:"Monthly support to vulnerable families in Eldoret and surrounding areas. We provide food packages to those in need.";s:10:"created_at";s:19:"2026-07-16 02:11:29";}i:1;a:4:{s:2:"id";i:2;s:5:"title";s:23:"Church Building Project";s:11:"description";s:141:"Building a new sanctuary to accommodate our growing congregation. The project includes a main hall, Sunday school rooms, and fellowship area.";s:10:"created_at";s:19:"2026-07-16 02:11:29";}i:2;a:4:{s:2:"id";i:3;s:5:"title";s:19:"Leadership Training";s:11:"description";s:117:"Raising workers for ministry through our biblical training programs. We equip leaders for churches across the region.";s:10:"created_at";s:19:"2026-07-16 02:11:29";}i:3;a:4:{s:2:"id";i:4;s:5:"title";s:17:"Youth Empowerment";s:11:"description";s:83:"Empowering young people with skills and spiritual foundation for a brighter future.";s:10:"created_at";s:19:"2026-07-16 02:11:29";}}}